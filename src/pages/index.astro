---
import Layout from '../layouts/Layout.astro';
import developersData from '../data/developers.json';

// Definimos el tipo para un desarrollador
interface Skill {
  name: string;
  icon?: string; // SVG path o nombre de icono
  years: number; // Años de experiencia
}

interface Proyecto {
  title: string;
  shortDescription: string;
  longDescription: string;
  tags: string[];
  image: string;
  images?: string[]; // Array de imágenes para el carrusel
  link?: string;
  pais: string;
}

interface Curso {
  titulo: string;
  plataforma: string;
  año: string;
  horas: number;
}

interface SocialLinks {
  instagram?: string;
  linkedin?: string;
  github?: string;
}

interface Recommendation {
  autor: string;
  cargo: string;
  relacion?: string;
  fecha?: string;
  mensaje: string;
}

interface Developer {
  slug: string;
  nombre: string;
  apellido: string;
  roles: string[];
  bio: string;
  foto?: string;
  social?: SocialLinks;
  whatsapp?: string;
  cv?: string;
  skills: Skill[];
  proyectos: Proyecto[];
  cursos: Curso[];
  recomendaciones?: Recommendation[];
}

const developers = developersData as Developer[];
const dev = developers[0]; // Oswaldo is the only/first entry

const resolvePath = (path: string | undefined) => {
  if (!path) return '#';
  if (path.startsWith('http')) return path;
  return path.startsWith('/') ? path : `/${path}`;
};

// Extraer todos los tags únicos de los proyectos
const allTags = Array.from(new Set(dev.proyectos.flatMap(p => p.tags)));
const hasRecommendations = dev.recomendaciones && dev.recomendaciones.length > 0;
const hasRecommendationCarousel = dev.recomendaciones && dev.recomendaciones.length > 3;
---

<Layout title={`Portafolio de ${dev.nombre} ${dev.apellido}`}>
  <div class="portfolio-container">
    <!-- Header Hero Section -->
    <header class="portfolio-hero" id="acerca-de">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="hero-name">Hola, soy <span class="highlight">{dev.nombre} {dev.apellido}</span></h1>
          <div class="hero-role">
            <span class="typewriter-role" data-roles={JSON.stringify(dev.roles)}></span>
          </div>
          <p class="hero-description">
            {dev.bio}
          </p>
          <div class="hero-buttons">
            {dev.whatsapp ? (
              <a href={`https://wa.me/${dev.whatsapp.replace(/[^0-9]/g, '')}`} class="btn-hire" target="_blank" rel="noopener noreferrer">
                <span>→</span> Contactar
              </a>
            ) : (
              <a href="#contacto" class="btn-hire">
                <span>→</span> Contactar
              </a>
            )}
            {dev.cv ? (
              <a href={resolvePath(dev.cv)} class="btn-cv" download>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Descargar CV
              </a>
            ) : (
              <a href="#" class="btn-cv">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Descargar CV
              </a>
            )}
          </div>
          <div class="hero-social">
            <span class="social-label">SÍGUEME</span>
            <div class="social-icons">
              {dev.social?.instagram && (
                <a href={dev.social.instagram} class="social-icon" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                  </svg>
                </a>
              )}
              {dev.social?.linkedin && (
                <a href={dev.social.linkedin} class="social-icon" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                    <rect x="2" y="9" width="4" height="12"></rect>
                    <circle cx="4" cy="4" r="2"></circle>
                  </svg>
                </a>
              )}
              {dev.social?.github && (
                <a href={dev.social.github} class="social-icon" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
        <div class="hero-image-wrapper">
          {dev.foto ? (
            <div class="image-container">
              <img src={resolvePath(dev.foto)} alt={dev.nombre} class="dev-photo" />
            </div>
          ) : (
            <div class="image-placeholder">
              <span>Foto</span>
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- Skills Section -->
    <section class="skills-section" id="skills">
      <div class="section-container">
        <h2 class="section-title">Habilidades Técnicas</h2>
        <div class="skills-tags">
          {dev.skills.map((skill) => (
            <div class="skill-tag">
              {skill.icon ? (
                <img src={resolvePath(skill.icon)} alt={skill.name} class="skill-icon" />
              ) : (
                <span class="skill-icon-text">{skill.name.charAt(0)}</span>
              )}
              <span class="skill-tag-name">{skill.name}</span>
              <span class="skill-tag-years">{skill.years} {skill.years === 1 ? 'año' : 'años'}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="projects-section" id="proyectos">
      <div class="section-container">
        <h2 class="section-title">Proyectos Realizados</h2>
        <div class="projects-filters-wrapper">
          <div class="projects-filters" id="projects-filters">
            <button class="filter-btn selected" data-filter="all">Todos</button>
            {allTags.map((tag) => (
              <button class="filter-btn" data-filter={tag}>{tag}</button>
            ))}
          </div>
        </div>
        <div class="projects-grid" id="projects-grid">
          {dev.proyectos.map((proyecto, index) => (
            <article class="project-card" data-tags={JSON.stringify(proyecto.tags)} data-index={index} style={index >= 6 ? "display: none;" : ""}>
              <div class="project-image-wrapper">
                <img src={resolvePath(proyecto.image)} alt={proyecto.title} class="project-image" />
                <div class="project-overlay">
                  <button
                    class="project-link"
                    data-project-index={index}
                    type="button"
                  >
                    Ver Proyecto →
                  </button>
                </div>
              </div>
              <div class="project-content">
                <div class="project-header">
                  <h3 class="project-title">{proyecto.title}</h3>
                </div>
                <p class="project-description">{proyecto.shortDescription}</p>
                <div class="project-tags">
                  {proyecto.tags.map((tag) => (
                    <span class="project-tag tag">{tag}</span>
                  ))}
                </div>
              </div>
              <div class="project-country-wrapper">
                <span class="project-country">{proyecto.pais}</span>
              </div>
            </article>
          ))}
        </div>
        {dev.proyectos.length > 6 && (
          <div class="load-more-container">
            <button class="load-more-btn" id="load-more-projects">
              <span>Ver más proyectos</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
          </div>
        )}
      </div>
    </section>

    <!-- Courses Section -->
    <section class="courses-section" id="cursos">
      <div class="section-container">
        <h2 class="section-title">Cursos Realizados</h2>
        <div class="courses-grid">
          {dev.cursos.map((curso) => (
            <div class="course-card">
              <div class="course-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                  <path d="M2 17l10 5 10-5"></path>
                  <path d="M2 12l10 5 10-5"></path>
                </svg>
              </div>
              <div class="course-content">
                <h3 class="course-title">{curso.titulo}</h3>
                <div class="course-info">
                  <span class="course-platform">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                      <line x1="8" y1="21" x2="16" y2="21"></line>
                      <line x1="12" y1="17" x2="12" y2="21"></line>
                    </svg>
                    {curso.plataforma}
                  </span>
                  <span class="course-year">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    {curso.año}
                  </span>
                  <span class="course-hours">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    {curso.horas}h
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {hasRecommendations && (
      <section class="recommendations-section" id="recomendaciones">
        <div class="section-container">
          <h2 class="section-title">Recomendaciones</h2>
          <div class={`recommendations-wrapper ${hasRecommendationCarousel ? 'carousel-active' : ''}`} data-carousel={hasRecommendationCarousel ? 'true' : 'false'}>
            <div class={`recommendations-list ${hasRecommendationCarousel ? 'is-carousel' : ''}`}>
              {dev.recomendaciones?.map((rec) => (
                <article class="recommendation-card">
                  <div class="recommendation-header">
                    <div>
                      <h3 class="recommendation-author">{rec.autor}</h3>
                      <p class="recommendation-role">{rec.cargo}</p>
                    </div>
                    {rec.fecha && <span class="recommendation-date">{rec.fecha}</span>}
                  </div>
                  {rec.relacion && <p class="recommendation-relationship">{rec.relacion}</p>}
                  <p class="recommendation-message">{rec.mensaje}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}
  </div>

  <!-- Modal de Proyecto -->
  <div class="project-modal" id="project-modal" role="dialog" aria-labelledby="modal-title" aria-hidden="true">
    <div class="modal-overlay" id="modal-overlay"></div>
    <div class="modal-content">
      <button class="modal-close" id="modal-close" aria-label="Cerrar modal">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="modal-body">
        <!-- Slider de Imágenes del Proyecto -->
        <div class="modal-image-container" id="modal-image-container">
          <div class="image-slider" id="image-slider">
            <img id="modal-image" class="modal-image" alt="" />
          </div>
          <button class="slider-btn slider-prev" id="slider-prev" aria-label="Imagen anterior" style="display: none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button class="slider-btn slider-next" id="slider-next" aria-label="Imagen siguiente" style="display: none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
          <div class="slider-indicators" id="slider-indicators" style="display: none;"></div>
        </div>

        <!-- Contenido del Modal -->
        <div class="modal-info">
          <h2 class="modal-title" id="modal-title"></h2>

          <div class="modal-meta">
            <div class="modal-tags" id="modal-tags"></div>
            <div class="modal-country" id="modal-country"></div>
          </div>

          <div class="modal-description">
            <p class="modal-description-short" id="modal-description-short"></p>
            <p class="modal-description-detailed" id="modal-description-detailed"></p>
          </div>

          <div class="modal-actions">
            <a class="modal-link-btn" id="modal-link-btn" target="_blank" rel="noopener noreferrer" style="display: none;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
              Visitar Sitio Web
            </a>
          </div>
        </div>
      </div>

      <!-- Botones de navegación entre proyectos -->
      <div class="modal-project-nav">
        <button class="modal-nav-btn modal-nav-prev" id="modal-nav-prev" aria-label="Proyecto anterior">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="modal-nav-btn modal-nav-next" id="modal-nav-next" aria-label="Proyecto siguiente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>
</Layout>

<script id="proyectos-data" type="application/json" set:html={JSON.stringify(dev.proyectos.map(p => ({
    ...p,
    image: resolvePath(p.image),
    images: p.images ? p.images.map((img: string) => resolvePath(img)) : undefined
  })))}></script>

<script>
  // Efecto Typewriter para los roles
  async function initTypewriter() {
    // Esperar a que las fuentes estén cargadas
    if (document.fonts && document.fonts.ready) {
      await document.fonts.ready;
    }
    // Esperar un frame adicional para asegurar que todo esté renderizado
    await new Promise(resolve => requestAnimationFrame(resolve));
    await new Promise(resolve => setTimeout(resolve, 50));

    const typewriterElement = document.querySelector('.typewriter-role') as HTMLElement;
    if (!typewriterElement) return;

    const roles = JSON.parse(typewriterElement.getAttribute('data-roles') || '[]');
    if (roles.length === 0) return;

    // Obtener todos los estilos computados del elemento real
    const computedStyle = window.getComputedStyle(typewriterElement);

    // Crear un elemento temporal idéntico al elemento real
    const tempSpan = document.createElement('span');
    tempSpan.style.visibility = 'hidden';
    tempSpan.style.position = 'absolute';
    tempSpan.style.top = '-9999px';
    tempSpan.style.left = '-9999px';
    tempSpan.style.display = 'inline-flex';
    tempSpan.style.alignItems = 'center';
    tempSpan.style.fontSize = computedStyle.fontSize;
    tempSpan.style.fontFamily = computedStyle.fontFamily;
    tempSpan.style.fontWeight = computedStyle.fontWeight;
    tempSpan.style.fontStyle = computedStyle.fontStyle;
    tempSpan.style.letterSpacing = computedStyle.letterSpacing;
    tempSpan.style.padding = computedStyle.padding;
    tempSpan.style.paddingLeft = computedStyle.paddingLeft;
    tempSpan.style.paddingRight = computedStyle.paddingRight;
    tempSpan.style.paddingTop = computedStyle.paddingTop;
    tempSpan.style.paddingBottom = computedStyle.paddingBottom;
    tempSpan.style.borderLeft = computedStyle.borderLeft;
    tempSpan.style.borderRight = computedStyle.borderRight;
    tempSpan.style.borderTop = computedStyle.borderTop;
    tempSpan.style.borderBottom = computedStyle.borderBottom;
    tempSpan.style.border = computedStyle.border;
    tempSpan.style.borderRadius = computedStyle.borderRadius;
    tempSpan.style.boxSizing = computedStyle.boxSizing;
    tempSpan.style.whiteSpace = 'nowrap';
    tempSpan.style.lineHeight = computedStyle.lineHeight;
    tempSpan.style.height = computedStyle.height;
    tempSpan.style.minHeight = computedStyle.minHeight;
    tempSpan.style.width = 'auto';
    tempSpan.style.minWidth = 'auto';
    tempSpan.style.maxWidth = 'none';

    document.body.appendChild(tempSpan);

    let maxWidth = 0;
    roles.forEach((role: string) => {
      tempSpan.textContent = role;
      // Forzar reflow para obtener medidas precisas
      void tempSpan.offsetWidth;
      void tempSpan.offsetHeight;
      // Usar scrollWidth para obtener el ancho completo del contenido
      // y getBoundingClientRect para incluir padding y border
      const scrollWidth = tempSpan.scrollWidth;
      const rect = tempSpan.getBoundingClientRect();
      // Usar el mayor entre scrollWidth y rect.width para asegurar precisión
      const width = Math.max(scrollWidth, rect.width);
      if (width > maxWidth) {
        maxWidth = width;
      }
    });

    document.body.removeChild(tempSpan);

    // Establecer el ancho exacto del contenedor (sin margen adicional innecesario)
    const isMobile = window.innerWidth <= 640;
    const fixedHeight = isMobile ? '50px' : '60px';

    // Usar el ancho calculado exactamente, solo agregar 2px mínimo para evitar problemas de redondeo
    const finalWidth = Math.ceil(maxWidth) + 2;

    typewriterElement.style.width = `${finalWidth}px`;
    typewriterElement.style.minWidth = `${finalWidth}px`;
    typewriterElement.style.height = fixedHeight;
    typewriterElement.style.minHeight = fixedHeight;

    let currentRoleIndex = 0;
    let currentCharIndex = 0;
    let isDeleting = false;
    let currentText = '';
    let typingSpeed = 100;
    let deletingSpeed = 50;
    let pauseTime = 2000;

    function typeWriter() {
      if (!typewriterElement) return;

      const currentRole = roles[currentRoleIndex];

      if (isDeleting) {
        currentText = currentRole.substring(0, currentCharIndex - 1);
        currentCharIndex--;
        typingSpeed = deletingSpeed;

        if (currentText === '') {
          isDeleting = false;
          currentRoleIndex = (currentRoleIndex + 1) % roles.length;
          typingSpeed = 500; // Pausa antes de escribir el siguiente
        }
      } else {
        currentText = currentRole.substring(0, currentCharIndex + 1);
        currentCharIndex++;
        typingSpeed = 100;

        if (currentText === currentRole) {
          typingSpeed = pauseTime;
          isDeleting = true;
        }
      }

      typewriterElement.textContent = currentText;
      setTimeout(typeWriter, typingSpeed);
    }

    setTimeout(typeWriter, 1000);
  }

  document.addEventListener('DOMContentLoaded', initTypewriter);

  // Filtros de proyectos y Load More
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const projectCards = document.querySelectorAll('.project-card');
    const loadMoreBtn = document.getElementById('load-more-projects') as HTMLButtonElement;
    const totalProjects = projectCards.length;
    let visibleCount = 6;
    let currentFilter = 'all';

    // Función para actualizar la visibilidad de proyectos basado en el filtro y el contador
    const updateProjectsVisibility = (filter: string, resetCount = false) => {
      if (resetCount) {
        visibleCount = 6;
      }

      const cardsArray = Array.from(projectCards) as HTMLElement[];
      let visibleInFilter = 0;

      cardsArray.forEach((card, index) => {
        const cardElement = card as HTMLElement;
        const tags = JSON.parse(card.getAttribute('data-tags') || '[]');
        const matchesFilter = filter === 'all' || tags.includes(filter);

        if (matchesFilter) {
          visibleInFilter++;
          // Mostrar solo si está dentro del rango visible
          if (visibleInFilter <= visibleCount) {
            cardElement.style.display = 'block';
            setTimeout(() => {
              cardElement.style.opacity = '1';
              cardElement.style.transform = 'translateY(0)';
            }, 10);
          } else {
            // Ocultar proyectos que están fuera del rango visible
            cardElement.style.display = 'none';
            cardElement.style.opacity = '0';
            cardElement.style.transform = 'translateY(20px)';
          }
        } else {
          // Ocultar proyectos que no coinciden con el filtro
          cardElement.style.opacity = '0';
          cardElement.style.transform = 'translateY(20px)';
          setTimeout(() => {
            cardElement.style.display = 'none';
          }, 300);
        }
      });

      // Mostrar/ocultar botón "mostrar más"
      if (loadMoreBtn) {
        if (visibleInFilter > visibleCount) {
          loadMoreBtn.classList.remove('hidden');
        } else {
          loadMoreBtn.classList.add('hidden');
        }
      }
    };

    // Función para mostrar más proyectos
    const showMoreProjects = () => {
      visibleCount += 6;
      updateProjectsVisibility(currentFilter, false);
    };

    // Event listeners para filtros
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        filterButtons.forEach(btn => btn.classList.remove('selected'));
        button.classList.add('selected');

        currentFilter = button.getAttribute('data-filter') || 'all';
        updateProjectsVisibility(currentFilter, true);
      });
    });

    // Event listener para botón "mostrar más"
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', showMoreProjects);
    }

    // Inicializar visibilidad
    updateProjectsVisibility('all', true);
  });

  // Carrusel de filtros para móvil
  document.addEventListener('DOMContentLoaded', () => {
    const filtersContainer = document.getElementById('projects-filters') as HTMLElement;
    const filtersWrapper = filtersContainer?.parentElement as HTMLElement;
    if (!filtersContainer || !filtersWrapper) return;

    // Solo activar en móvil
    const isMobile = () => window.innerWidth <= 768;

    let currentPage = 0;
    let totalPages = 0;
    let pageHeight = 0;
    let pagePositions: number[] = []; // Posiciones Y exactas de cada página
    let autoSlideInterval: ReturnType<typeof setInterval> | null = null;
    let isDragging = false;
    let startY = 0;
    let startTranslate = 0;
    let currentTranslate = 0;
    let isUserInteracting = false;

    // Calcular cuántas páginas necesitamos y la altura de una página
    const calculatePages = () => {
      if (!isMobile()) {
        totalPages = 1;
        pageHeight = 0;
        return;
      }

      const filterButtons = Array.from(filtersContainer.children) as HTMLElement[];
      if (filterButtons.length === 0) return;

      // Resetear cualquier transformación para medir correctamente
      filtersContainer.style.transform = 'translateY(0)';

      // Esperar un frame para que el navegador actualice el layout
      requestAnimationFrame(() => {
        // Obtener las posiciones reales de cada botón después del layout
        const buttonPositions = filterButtons.map((btn) => {
          const rect = btn.getBoundingClientRect();
          const containerRect = filtersContainer.getBoundingClientRect();
          return {
            element: btn,
            top: rect.top - containerRect.top,
            bottom: rect.bottom - containerRect.top,
            height: rect.height
          };
        });

        if (buttonPositions.length === 0) return;

        // Encontrar la altura de la primera línea
        const firstButtonTop = buttonPositions[0].top;
        const firstLineButtons = buttonPositions.filter(pos =>
          Math.abs(pos.top - firstButtonTop) < 10 // Tolerancia de 10px para la misma línea
        );
        const firstLineBottom = Math.max(...firstLineButtons.map(pos => pos.bottom));

        // Encontrar la altura de la segunda línea (si existe)
        const secondLineButtons = buttonPositions.filter(pos =>
          pos.top > firstLineBottom - 10 && pos.top < firstLineBottom + 100
        );

        let actualPageHeight = 0;

        if (secondLineButtons.length > 0) {
          // Hay segunda línea: altura = desde el inicio hasta el final de la segunda línea
          const secondLineBottom = Math.max(...secondLineButtons.map(pos => pos.bottom));
          actualPageHeight = secondLineBottom - firstButtonTop;

          // Calcular las posiciones de inicio de cada página
          pagePositions = [0]; // Primera página siempre empieza en 0

          let currentY = secondLineBottom;
          let pageIndex = 1;

          // Agrupar botones en páginas basándome en su posición Y
          while (currentY < buttonPositions[buttonPositions.length - 1].bottom) {
            // Encontrar dónde empieza la siguiente "página" de 2 líneas
            const nextPageStart = buttonPositions.find(pos =>
              pos.top >= currentY - 5
            );

            if (!nextPageStart) break;

            // Encontrar las 2 líneas de esta página
            const pageFirstLineButtons = buttonPositions.filter(pos =>
              Math.abs(pos.top - nextPageStart.top) < 10
            );
            const pageFirstLineBottom = Math.max(...pageFirstLineButtons.map(pos => pos.bottom));

            const pageSecondLineButtons = buttonPositions.filter(pos =>
              pos.top > pageFirstLineBottom - 10 && pos.top < pageFirstLineBottom + 100
            );

            if (pageSecondLineButtons.length > 0) {
              const pageSecondLineBottom = Math.max(...pageSecondLineButtons.map(pos => pos.bottom));
              pagePositions.push(nextPageStart.top - firstButtonTop);
              currentY = pageSecondLineBottom;
            } else {
              // Solo hay una línea en esta página
              pagePositions.push(nextPageStart.top - firstButtonTop);
              currentY = pageFirstLineBottom;
            }

            pageIndex++;
          }

          totalPages = pagePositions.length;
        } else {
          // Solo hay una línea: usar esa altura
          actualPageHeight = firstLineBottom - firstButtonTop;
          pagePositions = [0];
          totalPages = 1;
        }

        pageHeight = actualPageHeight;

        // Establecer altura del wrapper
        if (pageHeight > 0 && totalPages > 1) {
          filtersWrapper.style.height = `${pageHeight}px`;
          filtersWrapper.style.overflow = 'hidden';
        }

        // Asegurarse de que estamos en la página 0
        updateFiltersPosition(0, false);

        if (totalPages > 1) {
          startAutoSlide();
        }
      });
    };

    const updateFiltersPosition = (page: number, animate = true) => {
      if (totalPages <= 1) {
        filtersContainer.style.transform = 'translateY(0)';
        currentTranslate = 0;
        return;
      }

      currentPage = Math.max(0, Math.min(page, totalPages - 1));

      // Usar las posiciones exactas de cada página si están disponibles
      let translateY = 0;
      if (pagePositions.length > currentPage) {
        translateY = -pagePositions[currentPage];
      } else {
        // Fallback al cálculo anterior si no tenemos posiciones
        translateY = -(currentPage * pageHeight);
      }

      currentTranslate = translateY;
      filtersContainer.style.transition = animate ? 'transform 0.5s ease' : 'none';
      filtersContainer.style.transform = `translateY(${translateY}px)`;
    };

    const goToPage = (page: number, animate = true) => {
      if (totalPages <= 1) return;
      updateFiltersPosition(page, animate);
    };

    const nextPage = () => {
      if (totalPages <= 1) return;
      const next = (currentPage + 1) % totalPages;
      goToPage(next);
    };

    const startAutoSlide = () => {
      if (isUserInteracting || totalPages <= 1 || !isMobile()) return;
      stopAutoSlide();
      autoSlideInterval = setInterval(() => {
        if (!isUserInteracting && !isDragging && isMobile()) {
          nextPage();
        }
      }, 3000);
    };

    const stopAutoSlide = () => {
      if (autoSlideInterval) {
        clearInterval(autoSlideInterval);
        autoSlideInterval = null;
      }
    };

    // Swipe handlers
    const handlePointerDown = (e: PointerEvent) => {
      if (totalPages <= 1 || !isMobile()) return;
      isDragging = true;
      isUserInteracting = true;
      startY = e.clientY;
      startTranslate = currentTranslate;
      filtersContainer.style.transition = 'none';
      stopAutoSlide();
      filtersContainer.setPointerCapture(e.pointerId);
      e.preventDefault();
    };

    const handlePointerMove = (e: PointerEvent) => {
      if (!isDragging || totalPages <= 1 || !isMobile()) return;
      const deltaY = e.clientY - startY;
      let newTranslate = startTranslate + deltaY;

      // Calcular límites usando las posiciones exactas
      const maxTranslate = 0;
      let minTranslate = 0;
      if (pagePositions.length > 0) {
        minTranslate = -pagePositions[pagePositions.length - 1];
      } else {
        minTranslate = -(totalPages - 1) * pageHeight;
      }

      newTranslate = Math.max(minTranslate, Math.min(maxTranslate, newTranslate));
      currentTranslate = newTranslate;
      filtersContainer.style.transform = `translateY(${newTranslate}px)`;
    };

    const handlePointerUp = (e: PointerEvent) => {
      if (!isDragging || totalPages <= 1 || !isMobile()) return;
      isDragging = false;

      // Determinar a qué página ir según el desplazamiento
      const threshold = 50;
      const deltaY = currentTranslate - startTranslate;

      if (Math.abs(deltaY) > threshold) {
        if (deltaY < 0 && currentPage < totalPages - 1) {
          goToPage(currentPage + 1);
        } else if (deltaY > 0 && currentPage > 0) {
          goToPage(currentPage - 1);
        } else {
          goToPage(currentPage);
        }
      } else {
        goToPage(currentPage);
      }

      setTimeout(() => {
        isUserInteracting = false;
        if (isMobile()) {
          startAutoSlide();
        }
      }, 500);

      if (filtersContainer.hasPointerCapture && filtersContainer.hasPointerCapture(e.pointerId)) {
        filtersContainer.releasePointerCapture(e.pointerId);
      }
    };

    // Event listeners
    filtersContainer.addEventListener('pointerdown', handlePointerDown);
    filtersContainer.addEventListener('pointermove', handlePointerMove);
    filtersContainer.addEventListener('pointerup', handlePointerUp);
    filtersContainer.addEventListener('pointercancel', handlePointerUp);
    filtersContainer.addEventListener('pointerleave', (e: PointerEvent) => {
      if (isDragging) {
        handlePointerUp(e);
      }
    });

    // Pausar auto-slide cuando el usuario interactúa con los botones
    filtersContainer.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('filter-btn')) {
        isUserInteracting = true;
        stopAutoSlide();
        setTimeout(() => {
          isUserInteracting = false;
          if (isMobile()) {
            startAutoSlide();
          }
        }, 5000);
      }
    });

    // Inicializar
    const init = () => {
      if (!isMobile()) {
        filtersContainer.style.transform = '';
        filtersContainer.style.transition = '';
        filtersContainer.style.cursor = '';
        filtersWrapper.style.height = '';
        filtersWrapper.style.overflow = '';
        stopAutoSlide();
        return;
      }

      // Esperar a que se rendericen los botones y calcular páginas
      setTimeout(() => {
        calculatePages();
      }, 100);
    };

    // Ejecutar al cargar y al redimensionar
    init();

    let resizeTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        stopAutoSlide();
        init();
      }, 250);
    });
  });

  // Scroll Spy para el menú
  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('section[id], header[id]');
    const navLinks = document.querySelectorAll('.nav-link');
    const offset = 100; // Debe coincidir con scroll-padding-top

    function updateActiveLink() {
      let currentSection = '';
      const scrollPosition = window.scrollY;

      // Si estamos en la parte superior, activar "Acerca de"
      if (scrollPosition < 150) {
        currentSection = 'acerca-de';
      } else {
        // Buscar la sección que está más cerca del offset
        let closestSection = '';
        let closestDistance = Infinity;

        sections.forEach(section => {
          const rect = section.getBoundingClientRect();
          const sectionId = section.getAttribute('id');

          if (sectionId) {
            // Si la sección está en el viewport o ya pasó
            if (rect.top <= offset + 180) {
              const distance = Math.abs(rect.top - offset);
              if (distance < closestDistance) {
                closestDistance = distance;
                closestSection = sectionId;
              }
            }
          }
        });

        currentSection = closestSection || 'acerca-de';
      }

      // Actualizar los enlaces activos
      navLinks.forEach(link => {
        link.classList.remove('active');
        const href = link.getAttribute('href');
        if (href === `#${currentSection}`) {
          link.classList.add('active');
        }
      });
    }

    // Actualizar al cargar la página
    updateActiveLink();

    // Actualizar al hacer scroll
    let ticking = false;
    let scrollTimeout: ReturnType<typeof setTimeout>;

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateActiveLink();
          ticking = false;
        });
        ticking = true;
      }

      // Actualizar también después de que termine el scroll (útil para scroll suave)
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        updateActiveLink();
      }, 150);
    });

    // Actualizar cuando se hace clic en un enlace (después del scroll suave)
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        const href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          // Actualizar después de un delay para que el scroll suave termine
          setTimeout(() => {
            updateActiveLink();
          }, 300);
        }
      });
    });
  });

  // Modal de Proyecto
  document.addEventListener('DOMContentLoaded', () => {
    // Datos de proyectos para el modal
    const proyectosData = JSON.parse(document.getElementById('proyectos-data')?.textContent || '[]');
    const modal = document.getElementById('project-modal') as HTMLElement;
    const modalOverlay = document.getElementById('modal-overlay') as HTMLElement;
    const modalClose = document.getElementById('modal-close') as HTMLElement;
    const projectButtons = document.querySelectorAll('.project-link[data-project-index]') as NodeListOf<HTMLElement>;
    const modalImage = document.getElementById('modal-image') as HTMLImageElement;
    const modalTitle = document.getElementById('modal-title') as HTMLElement;
    const modalTags = document.getElementById('modal-tags') as HTMLElement;
    const modalCountry = document.getElementById('modal-country') as HTMLElement;
    const modalDescriptionShort = document.getElementById('modal-description-short') as HTMLElement;
    const modalDescriptionDetailed = document.getElementById('modal-description-detailed') as HTMLElement;
    const modalLinkBtn = document.getElementById('modal-link-btn') as HTMLAnchorElement;
    const sliderPrev = document.getElementById('slider-prev') as HTMLElement;
    const sliderNext = document.getElementById('slider-next') as HTMLElement;
    const sliderIndicators = document.getElementById('slider-indicators') as HTMLElement;
    const modalNavPrev = document.getElementById('modal-nav-prev') as HTMLElement;
    const modalNavNext = document.getElementById('modal-nav-next') as HTMLElement;

    let currentImageIndex = 0;
    let currentImages: string[] = [];
    let currentProjectIndex = 0;
    let totalProjects = proyectosData.length;

    // Función para actualizar la imagen mostrada
    const updateImage = () => {
      if (currentImages.length === 0) return;
      modalImage.src = currentImages[currentImageIndex];
      modalImage.alt = modalTitle.textContent || '';

      // Actualizar indicadores
      const indicators = sliderIndicators.querySelectorAll('.slider-indicator') as NodeListOf<HTMLElement>;
      indicators.forEach((indicator, index) => {
        indicator.classList.toggle('active', index === currentImageIndex);
      });
    };

    // Función para siguiente imagen
    const nextImage = () => {
      if (currentImages.length <= 1) return;
      currentImageIndex = (currentImageIndex + 1) % currentImages.length;
      updateImage();
    };

    // Función para imagen anterior
    const prevImage = () => {
      if (currentImages.length <= 1) return;
      currentImageIndex = (currentImageIndex - 1 + currentImages.length) % currentImages.length;
      updateImage();
    };

    // Función para ir a una imagen específica
    const goToImage = (index: number) => {
      if (currentImages.length <= 1) return;
      currentImageIndex = index;
      updateImage();
    };

    // Función para inicializar el slider
    const initSlider = (images: string[]) => {
      currentImages = images;
      currentImageIndex = 0;

      // Limpiar indicadores
      sliderIndicators.innerHTML = '';

      if (images.length > 1) {
        // Mostrar controles del slider
        sliderPrev.style.display = 'flex';
        sliderNext.style.display = 'flex';
        sliderIndicators.style.display = 'flex';

        // Crear indicadores
        images.forEach((_, index) => {
          const indicator = document.createElement('button');
          indicator.className = 'slider-indicator';
          if (index === 0) indicator.classList.add('active');
          indicator.setAttribute('aria-label', `Ir a imagen ${index + 1}`);
          indicator.addEventListener('click', () => goToImage(index));
          sliderIndicators.appendChild(indicator);
        });
      } else {
        // Ocultar controles del slider
        sliderPrev.style.display = 'none';
        sliderNext.style.display = 'none';
        sliderIndicators.style.display = 'none';
      }

      updateImage();
    };

    // Función para actualizar los botones de navegación entre proyectos
    const updateProjectNavButtons = () => {
      // Mostrar/ocultar botones según la posición
      if (totalProjects <= 1) {
        modalNavPrev.style.display = 'none';
        modalNavNext.style.display = 'none';
      } else {
        modalNavPrev.style.display = 'flex';
        modalNavNext.style.display = 'flex';
      }
    };

    // Función para navegar al siguiente proyecto
    const nextProject = () => {
      if (totalProjects <= 1) return;
      currentProjectIndex = (currentProjectIndex + 1) % totalProjects;
      openModal(currentProjectIndex, false);
    };

    // Función para navegar al proyecto anterior
    const prevProject = () => {
      if (totalProjects <= 1) return;
      currentProjectIndex = (currentProjectIndex - 1 + totalProjects) % totalProjects;
      openModal(currentProjectIndex, false);
    };

    // Función para abrir el modal
    const openModal = (projectIndex: number, updateCurrentIndex = true) => {
      if (updateCurrentIndex) {
        currentProjectIndex = projectIndex;
      }

      const proyecto = proyectosData[currentProjectIndex];
      if (!proyecto) return;

      // Obtener todas las imágenes: si hay array de imágenes, usarlo; si no, usar solo la imagen única
      const images = proyecto.images && proyecto.images.length > 0
        ? proyecto.images
        : [proyecto.image];

      // Inicializar el slider
      initSlider(images);

      // Llenar el modal con la información del proyecto
      modalTitle.textContent = proyecto.title;
      modalDescriptionShort.textContent = proyecto.shortDescription;

      // Descripción larga para el detalle
      if (proyecto.longDescription) {
        modalDescriptionDetailed.textContent = proyecto.longDescription;
        modalDescriptionDetailed.style.display = 'block';
      } else {
        modalDescriptionDetailed.style.display = 'none';
      }

      // Tags
      modalTags.innerHTML = '';
      proyecto.tags.forEach((tag: string) => {
        const tagSpan = document.createElement('span');
        tagSpan.className = 'modal-tag tag';
        tagSpan.textContent = tag;
        modalTags.appendChild(tagSpan);
      });

      // País
      modalCountry.innerHTML = `<span class="modal-country-text">🌍 ${proyecto.pais}</span>`;

      // Link del proyecto
      if (proyecto.link && proyecto.link !== '#' && proyecto.link.trim() !== '') {
        modalLinkBtn.href = proyecto.link;
        modalLinkBtn.style.display = 'inline-flex';
      } else {
        modalLinkBtn.style.display = 'none';
      }

      // Actualizar botones de navegación
      updateProjectNavButtons();

      // Mostrar el modal
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };

    // Función para cerrar el modal
    const closeModal = () => {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };

    // Event listeners
    projectButtons.forEach((button) => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        const projectIndex = parseInt(button.getAttribute('data-project-index') || '0');
        openModal(projectIndex);
      });
    });

    modalClose.addEventListener('click', closeModal);
    modalOverlay.addEventListener('click', closeModal);

    // Event listeners para el slider
    sliderNext.addEventListener('click', (e) => {
      e.stopPropagation();
      nextImage();
    });
    sliderPrev.addEventListener('click', (e) => {
      e.stopPropagation();
      prevImage();
    });

    // Event listeners para navegación entre proyectos
    modalNavNext.addEventListener('click', (e) => {
      e.stopPropagation();
      nextProject();
    });
    modalNavPrev.addEventListener('click', (e) => {
      e.stopPropagation();
      prevProject();
    });

    // Navegación con teclado
    document.addEventListener('keydown', (e) => {
      if (!modal.classList.contains('active')) return;

      // Cerrar con ESC
      if (e.key === 'Escape') {
        closeModal();
        return;
      }

      // Navegación entre proyectos con Ctrl/Cmd + flechas
      // O si no hay múltiples imágenes en el slider, usar flechas directamente
      const hasMultipleImages = currentImages.length > 1;
      const isCtrlOrCmd = e.ctrlKey || e.metaKey;

      if (e.key === 'ArrowRight') {
        e.preventDefault();
        if (isCtrlOrCmd || !hasMultipleImages) {
          // Navegar al siguiente proyecto
          nextProject();
        } else {
          // Navegar a la siguiente imagen del slider
          nextImage();
        }
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        if (isCtrlOrCmd || !hasMultipleImages) {
          // Navegar al proyecto anterior
          prevProject();
        } else {
          // Navegar a la imagen anterior del slider
          prevImage();
        }
      }
    });
  });

  // Carrusel de recomendaciones
  document.addEventListener('DOMContentLoaded', () => {
    const carouselWrappers = document.querySelectorAll('.recommendations-wrapper[data-carousel="true"]');

    carouselWrappers.forEach(wrapperNode => {
      const wrapper = wrapperNode as HTMLElement;
      const list = wrapper.querySelector('.recommendations-list.is-carousel') as HTMLElement | null;
      const cards = wrapper.querySelectorAll('.recommendation-card') as NodeListOf<HTMLElement>;
      if (!list || cards.length <= 3) return;

      let currentIndex = 0;
      let visibleCards = 3;
      let cardWidth = 0;
      let gap = 0;
      let maxIndex = 0;
      let maxTranslate = 0;
      let currentTranslate = 0;
      let intervalId: ReturnType<typeof setInterval> | null = null;
      let isDragging = false;
      let startX = 0;
      let startTranslate = 0;
      let isHovering = false;
      const defaultTransition = 'transform 1.2s ease';

      const getGap = () => {
        const styles = window.getComputedStyle(list);
        const rawGap = styles.columnGap || styles.gap || '0';
        return parseFloat(rawGap) || 0;
      };

      const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

      const applyTranslate = (translate: number, animate = false) => {
        currentTranslate = clamp(translate, 0, maxTranslate);
        list.style.transition = animate ? defaultTransition : 'none';
        list.style.transform = `translateX(-${currentTranslate}px)`;
      };

      const updateMetrics = () => {
        const firstCard = cards[0];
        if (!firstCard) return;
        cardWidth = firstCard.clientWidth;
        gap = getGap();
        const totalCardWidth = cardWidth + gap;
        visibleCards = Math.max(1, Math.round(wrapper.clientWidth / totalCardWidth));
        maxIndex = Math.max(0, cards.length - visibleCards);
        maxTranslate = totalCardWidth * maxIndex;
      };

      const goTo = (index: number, animate = true) => {
        currentIndex = clamp(index, 0, maxIndex);
        const targetTranslate = (cardWidth + gap) * currentIndex;
        applyTranslate(targetTranslate, animate);
      };

      const startAutoSlide = () => {
        if (isHovering) return;
        stopAutoSlide();
        if (maxIndex <= 0) return;
        intervalId = setInterval(() => {
          let nextIndex = currentIndex + 1;
          if (nextIndex > maxIndex) {
            nextIndex = 0;
          }
          goTo(nextIndex, true);
        }, 6000);
      };

      const stopAutoSlide = () => {
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
      };

      const handlePointerDown = (event: PointerEvent) => {
        if (event.pointerType === 'mouse' && event.button !== 0) return;
        event.preventDefault();
        isDragging = true;
        list.setPointerCapture(event.pointerId);
        list.classList.add('is-grabbing');
        startX = event.clientX;
        startTranslate = currentTranslate;
        list.style.transition = 'none';
        stopAutoSlide();
      };

      const handlePointerMove = (event: PointerEvent) => {
        if (!isDragging) return;
        const delta = event.clientX - startX;
        const nextTranslate = startTranslate - delta;
        applyTranslate(nextTranslate, false);
      };

      const endDrag = (event: PointerEvent) => {
        if (!isDragging) return;
        isDragging = false;
        if (list.hasPointerCapture && list.hasPointerCapture(event.pointerId)) {
          list.releasePointerCapture(event.pointerId);
        }
        list.classList.remove('is-grabbing');
        const nearestIndex = Math.round(currentTranslate / (cardWidth + gap));
        goTo(nearestIndex, true);
        if (!isHovering) {
          startAutoSlide();
        }
      };

      list.addEventListener('pointerdown', handlePointerDown);
      list.addEventListener('pointermove', handlePointerMove);
      list.addEventListener('pointerup', endDrag);
      list.addEventListener('pointercancel', endDrag);
      list.addEventListener('pointerleave', (event: PointerEvent) => {
        if (isDragging) {
          endDrag(event);
        }
      });

      wrapper.addEventListener('mouseenter', () => {
        isHovering = true;
        stopAutoSlide();
      });

      wrapper.addEventListener('mouseleave', () => {
        isHovering = false;
        startAutoSlide();
      });

      window.addEventListener('resize', () => {
        updateMetrics();
        goTo(currentIndex, false);
      });

      updateMetrics();
      goTo(0, false);
      startAutoSlide();
    });
  });

</script>

<style>
  .portfolio-container {
    padding: 0;
  }

  /* Hero Section */
  .portfolio-hero {
    height: auto;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 6rem;
    position: relative;
    overflow: hidden;
    background: var(--color-bg-main);
    scroll-margin-top: 100px;
  }

  .portfolio-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(43, 228, 194, 0.15) 0%, transparent 50%);
    animation: backgroundPulse 8s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes backgroundPulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    animation: slideInLeft 1s ease-out;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-family: var(--font-heading);
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: var(--color-text-white);
    font-weight: 700;
  }

  .hero-role {
    margin-bottom: 2rem;
    min-height: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    width: 100%;
    overflow: hidden;
  }

  .typewriter-role {
    display: inline-flex;
    align-items: center;
    background: var(--color-bg-sections);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 0.75rem 1.5rem;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text-white);
    text-align: left;
    white-space: nowrap;
    position: relative;
    box-sizing: border-box;
    min-height: 60px;
    height: 60px;
    line-height: 1.2;
    overflow: hidden;
    min-width: 150px;
    max-width: 100%;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .hero-description {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.7;
    max-width: 600px;
    margin-bottom: 2.5rem;
    color: var(--color-text-white);
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .btn-hire {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background-color: #ffffff;
    color: var(--color-text-button-selected);
    border: none;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    font-family: var(--font-button-selected);
    box-sizing: border-box;
    min-width: 200px;
    height: 48px;
  }

  .btn-hire:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
  }

  .btn-hire span {
    font-size: 1.2rem;
  }

  .btn-cv {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: var(--color-bg-main);
    color: var(--color-text-white);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    font-family: var(--font-button-selected);
    box-sizing: border-box;
    min-width: 200px;
    height: 48px;
  }

  .btn-cv:hover {
    background: var(--color-bg-sections);
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .btn-cv svg {
    width: 16px;
    height: 16px;
  }

  .hero-social {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .social-label {
    font-size: 0.75rem;
    color: var(--color-text-white);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    font-family: var(--font-paragraph);
    text-align: left;
  }

  .social-icons {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-bg-sections);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-text-white);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .social-icon:hover {
    background: var(--color-primary);
    color: var(--color-text-button-selected);
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(43, 228, 194, 0.3);
  }

  .social-icon svg {
    width: 20px;
    height: 20px;
  }

  .hero-image-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    animation: slideInRight 1s ease-out;
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .image-container {
    position: relative;
    width: 100%;
    max-width: 700px;
    overflow: visible;
  }

  .dev-photo {
    width: 100%;
    height: 100%;
    object-fit: fill;
    position: relative;
    display: block;
    z-index: 1;
  }

  /* Section Styles */
  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-family: var(--font-heading);
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-text-white);
    position: relative;
    display: inline-block;
    width: 100%;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
  }

  /* Skills Section */
  .skills-section {
    padding: 2rem 0;
    scroll-margin-top: 100px;
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .skill-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    background: var(--color-bg-sections);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    transition: all 0.3s ease;
    font-family: var(--font-tag);
  }

  .skill-tag:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
    background: rgba(43, 228, 194, 0.1);
    box-shadow: 0 5px 20px rgba(43, 228, 194, 0.2);
  }

  .skill-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .skill-icon-text {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .skill-tag-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text-white);
  }

  .skill-tag-years {
    font-weight: 500;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    padding-left: 0.5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
  }

  /* Projects Section */
  .projects-section {
    padding: 6rem 0;
    scroll-margin-top: 100px;
  }

  .projects-filters-wrapper {
    position: relative;
    margin-bottom: 3rem;
  }

  .projects-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .filter-btn {
    padding: 0.75rem 1.5rem;
    background: var(--color-button-normal-bg);
    color: var(--color-text-white);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 25px;
    font-family: var(--font-tag);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .filter-btn:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .filter-btn.selected {
    background: var(--color-primary);
    color: var(--color-text-button-selected);
    border-color: var(--color-primary);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .project-card {
    background: var(--color-bg-sections);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease, opacity 0.5s ease, transform 0.5s ease;
    opacity: 1;
    transform: translateY(0);
    position: relative;
  }

  .project-card:hover {
    transform: translateY(-10px);
    border-color: var(--color-primary);
    box-shadow: 0 20px 40px rgba(43, 228, 194, 0.3);
  }

  .project-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-image {
    transform: scale(1.1);
  }

  .project-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(43, 228, 194, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-link {
    color: var(--color-text-button-selected);
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    padding: 0.75rem 2rem;
    background: var(--color-text-white);
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .project-link:hover {
    transform: scale(1.05);
  }

  .project-content {
    padding: 2rem;
    position: relative;
    padding-bottom: 4rem;
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .project-title {
    font-size: 1.5rem;
    margin: 0;
    color: var(--color-text-white);
    font-family: var(--font-heading);
  }

  .project-country {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: rgba(43, 228, 194, 0.1);
    border: 1px solid var(--color-primary);
    border-radius: 20px;
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
    width: fit-content;
  }

  .project-country::before {
    content: '🌍';
    font-size: 1rem;
  }

  .project-country-wrapper {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    z-index: 1;
  }

  .project-description {
    opacity: 0.8;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-tag {
    padding: 0.4rem 1rem;
    background: var(--color-button-normal-bg);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    font-size: 0.85rem;
    color: var(--color-text-white);
    transition: all 0.3s ease;
  }

  .project-card:hover .project-tag {
    border-color: var(--color-primary);
    background: rgba(43, 228, 194, 0.1);
  }

  /* Load More Button */
  .load-more-container {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  .load-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: var(--color-bg-sections);
    color: var(--color-text-white);
    border: 2px solid var(--color-primary);
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-paragraph);
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .load-more-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--color-primary);
    transition: left 0.3s ease;
    z-index: 0;
  }

  .load-more-btn span,
  .load-more-btn svg {
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
  }

  .load-more-btn:hover {
    color: var(--color-text-button-selected);
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(43, 228, 194, 0.3);
  }

  .load-more-btn:hover::before {
    left: 0;
  }

  .load-more-btn:hover svg {
    color: var(--color-text-button-selected);
    transform: translateY(3px);
  }

  .load-more-btn svg {
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .load-more-btn.hidden {
    display: none;
  }

  /* Courses Section */
  .courses-section {
    padding: 6rem 0;
    scroll-margin-top: 100px;
    background: var(--color-bg-sections);
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .course-card {
    background: var(--color-bg-main);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .course-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-primary), var(--color-emphasis));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .course-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-primary);
    box-shadow: 0 15px 40px rgba(43, 228, 194, 0.25);
  }

  .course-card:hover::before {
    opacity: 1;
  }

  .course-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(43, 228, 194, 0.1);
    border: 2px solid var(--color-primary);
    border-radius: 12px;
    color: var(--color-primary);
    transition: all 0.3s ease;
  }

  .course-card:hover .course-icon {
    background: var(--color-primary);
    color: var(--color-text-button-selected);
    transform: scale(1.1) rotate(5deg);
  }

  .course-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .course-title {
    font-size: 1.3rem;
    color: var(--color-text-white);
    font-family: var(--font-heading);
    margin: 0;
    line-height: 1.3;
  }

  .course-info {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .course-platform,
  .course-year,
  .course-hours {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .course-platform svg,
  .course-year svg,
  .course-hours svg {
    width: 14px;
    height: 14px;
    color: var(--color-primary);
  }

  .course-hours {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Recommendations Section */
  .recommendations-section {
    padding: 6rem 0 8rem;
    scroll-margin-top: 100px;
    background: var(--color-bg-main);
  }

  .recommendations-wrapper {
    position: relative;
  }

  .recommendations-wrapper.carousel-active {
    overflow: hidden;
  }

  .recommendations-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .recommendations-list.is-carousel {
    display: flex;
    gap: 1.5rem;
    grid-template-columns: none;
    transition: transform 1.2s ease;
    will-change: transform;
    cursor: grab;
    user-select: none;
  }

  .recommendations-list.is-carousel .recommendation-card {
    flex: 0 0 calc(33.333% - 1rem);
    min-width: 280px;
  }

  .recommendations-list.is-carousel.is-grabbing {
    cursor: grabbing;
  }

  .recommendation-card {
    background: var(--color-bg-sections);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }

  .recommendation-card::before {
    content: '"';
    position: absolute;
    top: -20px;
    left: 20px;
    font-size: 5rem;
    color: rgba(43, 228, 194, 0.15);
    font-family: var(--font-heading);
  }

  .recommendation-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .recommendation-author {
    margin: 0;
    font-size: 1.2rem;
    color: var(--color-text-white);
  }

  .recommendation-role {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .recommendation-date {
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .recommendation-relationship {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .recommendation-message {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    text-align: center;
    }

    .hero-text {
      order: 2;
    }

    .hero-image-wrapper {
      order: 1;
    }

    .courses-grid {
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .recommendations-list.is-carousel .recommendation-card {
      flex: 0 0 calc(50% - 1rem);
    }
  }

  @media (max-width: 640px) {
    .portfolio-hero {
      padding: 4rem 1.5rem;
    }

    .hero-name {
      font-size: 2rem;
    }

    .hero-role {
      min-height: 50px;
      height: 50px;
    }

    .typewriter-role {
      min-height: 50px;
      height: 50px;
      font-size: 1.25rem;
    }

    .section-container {
      padding: 0 1.5rem;
    }

    .skills-tags {
      justify-content: flex-start;
    }

    .skill-tag {
      padding: 0.75rem 1.25rem;
      font-size: 0.9rem;
    }

    .skill-icon {
      width: 18px;
      height: 18px;
    }

    .skill-icon-text {
      width: 18px;
      height: 18px;
      font-size: 0.85rem;
    }

    .courses-grid {
      grid-template-columns: 1fr;
    }

    .recommendations-list.is-carousel .recommendation-card {
      flex: 0 0 100%;
    }

    /* Carrusel de filtros en móvil */
    .projects-filters-wrapper {
      overflow: hidden;
      position: relative;
      -webkit-overflow-scrolling: touch;
      /* La altura se calculará dinámicamente con JS */
    }

    .projects-filters {
      cursor: grab;
      user-select: none;
      touch-action: pan-y;
      will-change: transform;
    }

    .projects-filters:active {
      cursor: grabbing;
    }
  }

  /* Modal de Proyecto */
  /* Modal de Proyecto - Layout horizontal */
  .project-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .project-modal.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
  }

  .modal-content {
    position: relative;
    background: var(--color-bg-sections);
    border-radius: 20px;
    max-width: 1100px;
    width: 92%;
    max-height: 88vh;
    overflow: hidden;
    z-index: 1;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: var(--color-text-white);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .modal-close:hover {
    background: var(--color-primary);
    color: var(--color-text-button-selected);
  }

  /* Layout horizontal: imagen izquierda, info derecha */
  .modal-body {
    display: flex;
    flex-direction: row;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .modal-image-container {
    position: relative;
    width: 50%;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--color-bg-main);
  }

  .modal-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .image-slider {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.6);
    border: none;
    color: var(--color-text-white);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
